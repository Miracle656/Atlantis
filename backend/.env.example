# ============================================================
# ATLANTIS backend — example environment.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# --- Server ---------------------------------------------------
PORT=3001
NODE_ENV=development

# --- Sui network ---------------------------------------------
# 'testnet' | 'mainnet' | 'devnet'
SUI_NETWORK=testnet

# --- Existing: Enoki gasless sponsorship ---------------------
# Backend-side Enoki PRIVATE API key. Select "PRIVATE" key type at
# https://portal.enoki.mystenlabs.com
ENOKI_API_KEY=enoki_private_YOUR_KEY_HERE

# --- Existing: dapp_registry interaction verification --------
# Admin signer for record_interaction calls via IndexerCap.
# Hex or bech32 (suiprivkey...).
ADMIN_SECRET_KEY=

# Object IDs from the deployed dapp_registry package (mamiwaterc).
PACKAGE_ID=
REGISTRY_ID=
INDEXER_CAP_ID=

# --- NEW: agent_reports module --------------------------------
# Set after deploying agent_reports/ via `sui client publish`.
# See issue #1 in docs/issues/CONTRIBUTOR_ISSUES.md
AGENT_REPORTS_PACKAGE_ID=
AGENT_REPORTS_REGISTRY_ID=
AGENT_CAP_ID=

# --- NEW: Anthropic API --------------------------------------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- NEW: MemWal ---------------------------------------------
# Generate a delegate key + account at https://staging.memwal.ai (testnet)
# or https://memwal.ai (mainnet). Relayer URL must match the network.
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.staging.memwal.ai

# --- Optional: Blockberry (for metrics specialist) -----------
# Backend mirror of the frontend key. https://docs.blockberry.one/
BLOCKBERRY_API_KEY=
