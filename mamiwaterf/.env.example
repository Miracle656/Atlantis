# Environment Variables Template
# Copy this file to .env and fill in your values

# Sui Network Configuration
VITE_NETWORK=testnet

# Deployed Contract IDs
VITE_PACKAGE_ID=your_package_id_here
VITE_REGISTRY_ID=your_registry_id_here

# Enoki Configuration
VITE_ENOKI_API_KEY=your_enoki_api_key_here

# Sponsor Wallet (for gasless transactions)
VITE_SPONSOR_ADDRESS=your_sponsor_wallet_address_here
SPONSOR_PRIVATE_KEY=your_sponsor_private_key_here

# Blockberry API
VITE_BLOCKBERRY_API_KEY=your_blockberry_api_key_here

# Backend API URL — points at the deployed backend (e.g. Render).
# In production set this to your Render URL, e.g. https://atlantis-backend.onrender.com
VITE_BACKEND_URL=http://localhost:3001

# TradePort / indexer.xyz — NFT Data API
VITE_TRADEPORT_API_KEY=
VITE_TRADEPORT_API_USER=atlantis
